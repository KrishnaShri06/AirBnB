<% layout("layouts/boilerplate") %>
    <div class="row">
        <div class="col-6 col-md-8 offset-2">
            <h1>Edit your property details</h1>
            <form action="/listings/<%= listing._id %>/edit" method="post" class="needs-validation" novalidate>
                <div class="mb-3"><label for="title">Title</label><input placeholder="enter title" name="title"
                        id="title" type="text" value="<%= listing.title %>" class="form-control" required>
                    <div class="invalid-feedback">
                        Please enter title.
                    </div>
                </div>
                <div class="mb-3"><label for="description">Description</label><textarea placeholder="enter description"
                        name="description" id="description" type="text" value="<%= listing.description %>"
                        class="form-control" required></textarea>
                    <div class="invalid-feedback">
                        Please enter description.
                    </div>
                </div>
                <div class="mb-3"><label for="image">Image</label><input placeholder="enter image url/link" name="image"
                        id="image" type="text" value="<%= listing.image %>" class="form-control" required>
                    <div class="invalid-feedback">
                        Please enter image URL.
                    </div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4"><label for="price">Price</label>
                        <input placeholder="enter price" name="price" id="price" type="number" class="form-control"
                            value="<%= listing.price %>" required>
                        <div class="invalid-feedback">
                            Please enter price.
                        </div>
                    </div>
                    <div class="mb-3 col-md-8"> <label for="location">Location</label>
                        <input placeholder="enter location" name="location" id="location" type="text"
                            class="form-control" value="<%= listing.location %>" required>
                        <div class="invalid-feedback">
                            Please enter location.
                        </div>
                    </div>
                </div>
                <div class="mb-3"> <label for="country">Country</label>
                    <input placeholder="enter country" name="country" type="text" class="form-control"
                        value="<%= listing.country %>" required>
                    <div class="invalid-feedback">
                        Please enter country.
                    </div>
                </div>
                <button type="submit" class="btn btn-danger mb-3">Submit</button>
            </form>
        </div>
    </div>